# =============================================================================
# KTM Apartments — frontend environment (Next.js + optional Vite client)
# Copy to `.env` or `.env.local` and adjust:
#   cp .env.example .env
# Next.js loads: .env, .env.local, .env.development.local (see Next.js docs).
# Only variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# =============================================================================

# --- API (required for real data; MSW tests may override in tests) -----------
# Production default in code: https://api.ktmapartments.com/api/v1
# Local FastAPI (KTM-Apartments-Back) example:
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1

# --- Railway deployment notes --------------------------------------------------
# Railway injects PORT automatically; do not hardcode it.
# For production deployment, set NEXT_PUBLIC_API_URL to your live backend URL.

# --- Mock API mode (global frontend toggle) -----------------------------------
# NEXT_PUBLIC_USE_MSW is the single global toggle for mock vs backend behavior.
# true  => frontend uses MSW mock handlers and mock files.
# false => frontend bypasses MSW and calls backend APIs.
# NEXT_PUBLIC_USE_MSW=false

# --- Maps (Leaflet / OpenStreetMap) ------------------------------------------
# Optional: custom raster tile URL template ({s}, {z}, {x}, {y}).
# Leave unset to use default OpenStreetMap tiles.
# NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# --- Legacy Vite client (`frontend/client`, optional) ------------------------
# Used only if you run the Vite app; not used by `next dev`.
# VITE_OAUTH_PORTAL_URL=
# VITE_APP_ID=
# VITE_ANALYTICS_ENDPOINT=
# VITE_ANALYTICS_WEBSITE_ID=

# --- Optional Node server (`frontend/server/index.ts`) -----------------------
# PORT=3000
 