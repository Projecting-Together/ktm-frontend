# =============================================================================
# KTM Apartments — frontend environment (Next.js + optional Vite client)
# Copy to `.env` or `.env.local` and adjust:
#   cp .env.example .env
# Next.js loads: .env, .env.local, .env.development.local (see Next.js docs).
# Playwright also loads these via `loadEnvConfig` in `playwright.config.ts`.
# Only variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# =============================================================================

# --- API (required for real data; MSW tests may override in tests) -----------
# Production default in code: https://api.ktmapartments.com/api/v1
# Local FastAPI (KTM-Apartments-Back) example:
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1

# --- Railway deployment notes --------------------------------------------------
# Railway injects PORT automatically; do not hardcode it.
# For production deployment, set NEXT_PUBLIC_API_URL to your live backend URL.

# --- Mock API mode (global frontend toggle) -----------------------------------
# NEXT_PUBLIC_USE_MSW is the single global toggle for mock vs backend behavior.
# true  => frontend uses MSW mock handlers and mock files.
# false => frontend bypasses MSW and calls backend APIs.
NEXT_PUBLIC_USE_MSW=true

# --- Home page banners (optional full URLs; unset = default Unsplash images in code)
# NEXT_PUBLIC_HERO_BANNER_URL=https://example.com/hero.jpg
# NEXT_PUBLIC_CTA_BANNER_URL=https://example.com/cta.jpg
# Backend can override via GET /api/v1/site-config (heroBannerUrl, ctaBannerUrl) when server env is set.

# --- Maps (Leaflet) ----------------------------------------------------------
# Default basemap is Esri World Street Map (English/Latin-friendlier labels in Nepal).
# Optional: override raster tile URL. OSM uses {z}/{x}/{y}; Esri uses {z}/{y}/{x}.
# NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
# If you override tiles, set attribution to match your provider:
# NEXT_PUBLIC_MAP_TILE_ATTRIBUTION=&copy; OpenStreetMap contributors

# --- Optional Node server (`frontend/server/index.ts`) -----------------------
PORT=3000

# --- Playwright E2E (`pnpm exec playwright test`) ------------------------------
# Optional; defaults match `playwright.config.ts`. Uncomment to persist settings.
PLAYWRIGHT_TEST_DIR=./tests/e2e
PLAYWRIGHT_TEST_DIR=__tests__/e2e
PLAYWRIGHT_USE_NEXT_DEV=1
PLAYWRIGHT_E2E_PORT=4188
PLAYWRIGHT_MSW_API_URL=http://localhost:4188/api/v1
PLAYWRIGHT_MSW=0
 